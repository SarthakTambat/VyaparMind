# ============== SUPABASE (Database) ==============
# Get these from: https://app.supabase.com → Your Project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=your-service-role-key-here

# ============== AI / LLM ==============
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# ============== AUTH ==============
JWT_SECRET=your-secret-key-here

# ============== PAYMENTS ==============
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ============== CORS ==============
CORS_ORIGINS=*
